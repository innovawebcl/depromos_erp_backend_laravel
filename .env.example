# Depromos ERP Backend - Variables de Entorno

# JWT (OBLIGATORIO - generar con: php -r "echo bin2hex(random_bytes(32));")
JWT_SECRET=
JWT_TTL_SECONDS=28800

# Base de datos
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=backoffice
DB_USERNAME=backoffice
DB_PASSWORD=backoffice
DB_ROOT_PASSWORD=root

# App
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/Santiago

# Admin inicial (opcional, si no se define se genera aleatoriamente)
# ADMIN_DEFAULT_PASSWORD=
