# =============================================================================
# Depromos ERP - Variables de Entorno
# Copiar a .env y configurar antes de levantar:  cp .env.example .env
# =============================================================================

# --- JWT (OBLIGATORIO) ---
# Generar con: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_TTL_SECONDS=28800

# --- Base de Datos ---
DB_DATABASE=backoffice
DB_USERNAME=backoffice
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_EXTERNAL_PORT=33066

# --- App ---
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# --- Web ---
WEB_PORT=80

# --- Frontend Path (relativo al docker-compose.yml) ---
# Ajustar si los repos están en otra ubicación
FRONTEND_PATH=../depromos_erp_frontend_angular/frontend

# --- Admin Inicial (opcional) ---
# Si no se define, el seeder genera una contraseña aleatoria y la muestra en consola
# ADMIN_DEFAULT_PASSWORD=
